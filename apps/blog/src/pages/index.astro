---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="my">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script src="https://cdn.tailwindcss.com"></script>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans">
		
		<header class="max-w-4xl mx-auto py-20 px-6 text-center">
			<h1 class="text-5xl font-extrabold tracking-tight mb-4 bg-gradient-to-r from-orange-500 to-yellow-500 bg-clip-text text-transparent">
				Hi, I'm {name}
			</h1>
			<p class="text-xl text-slate-600 mb-8">
				Full-Stack Developer | Serverless Enthusiast | Cloudflare Builder
			</p>
			<div class="flex justify-center gap-4">
				<a href="#projects" class="bg-slate-900 text-white px-6 py-2 rounded-full hover:bg-slate-700 transition">View Projects</a>
				<a href="mailto:contact@example.com" class="border border-slate-300 px-6 py-2 rounded-full hover:bg-slate-100 transition">Contact Me</a>
			</div>
		</header>

		<section class="max-w-3xl mx-auto px-6 py-12 border-t border-slate-200">
			<h2 class="text-2xl font-bold mb-4">About Me</h2>
			<p class="text-lg leading-relaxed text-slate-700">
				မင်္ဂလာပါ၊ ကျွန်တော်ကတော့ ရှုပ်ထွေးတဲ့ ပြဿနာတွေကို ရိုးရှင်းပြီး မြန်ဆန်တဲ့ နည်းပညာတွေနဲ့ ဖြေရှင်းရတာကို ဝါသနာပါတဲ့ Developer တစ်ယောက်ပါ။ 
				အထူးသဖြင့် <strong>Astro</strong> နဲ့ <strong>Cloudflare Ecosystem</strong> ကို အသုံးချပြီး Performance အကောင်းဆုံး Application တွေ တည်ဆောက်နေပါတယ်။
			</p>
		</section>

		<section id="projects" class="max-w-4xl mx-auto px-6 py-12">
			<h2 class="text-2xl font-bold mb-8">Featured Project</h2>
			
			<div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition">
				<div class="flex items-center gap-2 mb-4 text-orange-600 font-semibold text-sm">
					<span>#Cloudflare</span> <span>#Astro</span> <span>#Serverless</span>
				</div>
				<h3 class="text-2xl font-bold mb-4">Leo Drive: Serverless Cloud Storage</h3>
				<p class="text-slate-600 mb-6 leading-relaxed">
					Cloudflare R2 (Storage) နဲ့ D1 (Database) ကို အသုံးပြုပြီး တည်ဆောက်ထားတဲ့ ကိုယ်ပိုင် Cloud Storage စနစ် ဖြစ်ပါတယ်။ 
					Egress fees မရှိဘဲ မြန်ဆန်တဲ့ Edge Network ပေါ်မှာ အလုပ်လုပ်ပါတယ်။
				</p>
				<div class="space-y-4">
					<h4 class="font-bold text-slate-800 underline">Key Features:</h4>
					<ul class="list-disc list-inside text-slate-600 space-y-1">
						<li>R2 Object Storage for files</li>
						<li>D1 SQLite for Metadata</li>
						<li>JWT Authentication Middleware</li>
						<li>Fast Edge Performance via Workers</li>
					</ul>
				</div>
			</div>
		</section>

		<footer class="text-center py-20 text-slate-400 text-sm">
			<p>© 2026 {name}. Built with Astro & ❤️</p>
		</footer>

	</body>
</html>
