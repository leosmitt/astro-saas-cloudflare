# Keystatic GitHub Mode Configuration
# Follow setup guide: https://keystatic.com/docs/github-mode

# Your GitHub repository details (PUBLIC_ prefix required for Astro)
PUBLIC_KEYSTATIC_REPO_OWNER=leosmitt
PUBLIC_KEYSTATIC_REPO_NAME=leo-protfolio

# GitHub OAuth App Credentials
# Create at: https://github.com/settings/developers
KEYSTATIC_GITHUB_CLIENT_ID=Ov23liODnFDonbJ3yNTl
KEYSTATIC_GITHUB_CLIENT_SECRET=177e97e60dc934031ff99cae48ed6be27f604fa6

# Random secret for signing cookies (generate with: openssl rand -base64 32)
KEYSTATIC_SECRET=your_random_secret_here

# Public Keystatic GitHub App Slug (set this to enable GitHub mode)
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=https://leosmitt.us.ci/login/OAuth-register
